// 1. Prisma Client 생성기 설정
generator client {
  provider = "prisma-client-js"
}

// 2. 데이터베이스 연결 설정 (이 부분이 빠져있어서 에러가 난 것입니다)
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
    MATCHING
    WAIT
    PLAY
}

// 3. 사용할 데이터베이스 모델 (프로젝트에 맞게 수정 가능)
model User {
  id       Int    @id @default(autoincrement())
  nickname String @unique
  password String
  cntWin   Int  @default(0)
  cntLose   Int  @default(0)
  status   UserStatus @default(WAIT)
}